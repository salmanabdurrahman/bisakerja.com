# App basics
APP_NAME=bisakerja-api
APP_ENV=development
HTTP_PORT=8080

# Database (Postgres + pool)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bisakerja?sslmode=disable
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MIN_OPEN_CONNS=2
DATABASE_MAX_CONN_LIFETIME=30m
DATABASE_MAX_CONN_IDLE_TIME=5m
DATABASE_CONNECT_TIMEOUT=5s

# Server lifecycle & workers
SHUTDOWN_TIMEOUT=10s
WORKER_TICK_INTERVAL=15s

# Job scraper settings
SCRAPER_PAGE_SIZE=30
SCRAPER_MAX_PAGES=1
SCRAPER_KEYWORDS=backend,frontend,intern

# Scraper provider auth
JOBSTREET_BEARER_TOKEN=
JOBSTREET_COOKIE=
JOBSTREET_EC_SESSION_ID=
JOBSTREET_EC_VISITOR_ID=
GLINTS_COOKIE=

# Auth (JWT tokens)
AUTH_JWT_SECRET=change-this-jwt-secret
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h

# Mayar payment API
MAYAR_BASE_URL=https://api.mayar.id/hl/v1
MAYAR_API_KEY=
MAYAR_REQUEST_TIMEOUT=5s
MAYAR_MAX_RETRIES=3

# Billing & webhook
BILLING_WEBHOOK_TOKEN=change-this-webhook-token
BILLING_REDIRECT_ALLOWLIST=app.bisakerja.com,localhost:3000
BILLING_IDEMPOTENCY_WINDOW=15m
BILLING_USER_RATE_LIMIT_WINDOW=10s
