# Path-only public API base for browser requests (keep same-origin to avoid CORS).
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Upstream API origin used by Next.js rewrites and SSR fetches.
API_ORIGIN=http://localhost:8080

# Midtrans Snap.js integration
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
NEXT_PUBLIC_MIDTRANS_ENV=sandbox
